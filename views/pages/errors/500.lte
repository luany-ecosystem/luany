<!DOCTYPE html>
<html lang="<?php echo htmlspecialchars(locale(), ENT_QUOTES, 'UTF-8'); ?>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>500 — Server Error | {{ env('APP_NAME', 'Luany') }}</title>
    <link rel="icon" type="image/svg+xml" href="{{ asset('images/icon/luany.svg') }}">
    <style>
        /* ── Reset ─────────────────────────────────────────────── */
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        a    { color: inherit; text-decoration: none; }

        /* ── Tokens ─────────────────────────────────────────────── */
        :root {
            --purple:        #5B3171;
            --purple-mid:    #7A4493;
            --purple-glass:  rgba(91, 49, 113, 0.15);
            --purple-border: rgba(91, 49, 113, 0.35);
            --orange:        #E6874A;
            --orange-glass:  rgba(230, 135, 74, 0.15);
            --red:           #F2441D;
            --dark:          #010213;
            --dark-card:     #0D0D26;
            --gradient:      linear-gradient(135deg, #5B3171 0%, #E6874A 100%);
            --text:          rgba(255, 255, 255, 0.95);
            --text-muted:    rgba(255, 255, 255, 0.55);
            --text-faint:    rgba(255, 255, 255, 0.25);
            --border:        rgba(91, 49, 113, 0.25);
            --radius-sm:     4px;
            --radius-md:     8px;
            --radius-full:   9999px;
            --ease:          cubic-bezier(0.4, 0, 0.2, 1);
            --transition:    .2s var(--ease);
            --mono:          'JetBrains Mono', 'Fira Code', monospace;
            --sans:          'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        /* ── Base ───────────────────────────────────────────────── */
        body {
            font-family: var(--sans);
            background: var(--dark);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Background ─────────────────────────────────────────── */
        .error-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
        }
        .error-bg-glow {
            position: absolute;
            border-radius: 50%;
            filter: blur(120px);
            opacity: .35;
        }
        .error-bg-glow--left {
            width: 600px; height: 600px;
            left: -200px; top: 50%;
            transform: translateY(-50%);
            background: radial-gradient(circle, rgba(91,49,113,.8) 0%, transparent 70%);
            animation: drift-left 18s ease-in-out infinite alternate;
        }
        .error-bg-glow--right {
            width: 400px; height: 400px;
            right: -100px; bottom: 10%;
            background: radial-gradient(circle, rgba(91,49,113,.6) 0%, transparent 70%);
            animation: drift-right 22s ease-in-out infinite alternate;
        }
        .error-bg-grid {
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(91,49,113,.06) 1px, transparent 1px),
                linear-gradient(90deg, rgba(91,49,113,.06) 1px, transparent 1px);
            background-size: 48px 48px;
            mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 100%);
        }

        @keyframes drift-left  { to { transform: translateY(-50%) translate(3vw, 4vh) scale(1.08); } }
        @keyframes drift-right { to { transform: translate(-4vw, -3vh) scale(1.12); } }
        @keyframes fadeInUp    { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }
        @keyframes pulse-dot   { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: .4; transform: scale(.7); } }
        @keyframes gradient-shift {
            0%   { background-position: 0% 50%; }
            50%  { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* ── Main content ───────────────────────────────────────── */
        .error-main {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 2rem;
            animation: fadeInUp .6s var(--ease) both;
        }

        /* ── Eyebrow ────────────────────────────────────────────── */
        .error-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            font-family: var(--mono);
            font-size: .75rem;
            font-weight: 700;
            letter-spacing: .15em;
            text-transform: uppercase;
            color: var(--orange);
            margin-bottom: 2rem;
            padding: .35rem 1rem;
            background: var(--orange-glass);
            border: 1px solid rgba(230,135,74,.25);
            border-radius: var(--radius-full);
        }
        .error-eyebrow-dot {
            width: 6px; height: 6px;
            border-radius: var(--radius-full);
            background: var(--orange);
            animation: pulse-dot 2s ease infinite;
        }

        /* ── Numeral ────────────────────────────────────────────── */
        .error-numeral {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .05em;
            font-family: var(--mono);
            font-size: clamp(7rem, 25vw, 18rem);
            font-weight: 800;
            line-height: .9;
            letter-spacing: -.04em;
            margin-bottom: 2rem;
        }
        .error-numeral-char { opacity: .12; }
        .error-numeral-char--accent {
            opacity: 1;
            background: var(--gradient);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradient-shift 5s ease infinite;
            filter: drop-shadow(0 0 48px rgba(230,135,74,.4));
        }

        /* ── Description ────────────────────────────────────────── */
        .error-description {
            font-size: clamp(1rem, 2vw, 1.15rem);
            color: var(--text-muted);
            line-height: 1.75;
            margin-bottom: 2.5rem;
            max-width: 480px;
            margin-left: auto;
            margin-right: auto;
        }

        /* ── Actions ────────────────────────────────────────────── */
        .error-actions {
            display: flex;
            gap: .75rem;
            justify-content: center;
            flex-wrap: wrap;
        }
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            padding: .75rem 1.75rem;
            font-family: var(--mono);
            font-size: .875rem;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
            border: none;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: all var(--transition);
            text-decoration: none;
            white-space: nowrap;
        }
        .btn-primary {
            background: var(--gradient);
            background-size: 200% 200%;
            color: #fff;
            box-shadow: 0 4px 16px rgba(230,135,74,.25);
            animation: gradient-shift 4s ease infinite;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(242,68,29,.5);
        }
        .btn-ghost {
            background: var(--purple-glass);
            color: var(--text-muted);
            border: 1px solid var(--border);
        }
        .btn-ghost:hover {
            background: rgba(91,49,113,.25);
            color: var(--text);
        }

        @media (max-width: 480px) {
            .error-actions { flex-direction: column; align-items: center; }
            .btn { width: 100%; max-width: 280px; }
        }
    </style>
</head>
<body>

    <div class="error-bg" aria-hidden="true">
        <div class="error-bg-glow error-bg-glow--left"></div>
        <div class="error-bg-glow error-bg-glow--right"></div>
        <div class="error-bg-grid"></div>
    </div>

    <main class="error-main">

        <div class="error-eyebrow">
            <span class="error-eyebrow-dot" aria-hidden="true"></span>
            <?php echo htmlspecialchars(__('500.eyebrow'), ENT_QUOTES, 'UTF-8'); ?>
        </div>

        <h1 class="error-numeral" aria-label="500">
            <span class="error-numeral-char">5</span>
            <span class="error-numeral-char error-numeral-char--accent">0</span>
            <span class="error-numeral-char">0</span>
        </h1>

        <p class="error-description">
            <?php echo __('500.description'); ?>
        </p>

        <div class="error-actions">
            <a href="{{ url('/') }}" class="btn btn-primary"><?php echo htmlspecialchars(__('500.back_home'), ENT_QUOTES, 'UTF-8'); ?></a>
            <button class="btn btn-ghost" onclick="location.reload()"><?php echo htmlspecialchars(__('500.try_again'), ENT_QUOTES, 'UTF-8'); ?></button>
        </div>

    </main>

</body>
</html>
