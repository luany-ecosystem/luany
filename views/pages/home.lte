                </div>
                <pre><span class="tok-tag">&lt;ul&gt;</span>
<span class="tok-directive">&#64;foreach</span><span class="tok-punct">(</span><span class="tok-expr">$users as $user</span><span class="tok-punct">)</span>
    <span class="tok-tag">&lt;li</span> <span class="tok-attr">class</span>=<span class="tok-str">"user-item"</span><span class="tok-tag">&gt;</span>
        <span class="tok-punct">&#123;&#123;</span> <span class="tok-expr">$user['name']</span> <span class="tok-punct">&#125;&#125;</span>
