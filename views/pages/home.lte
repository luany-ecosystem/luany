@section('title', ($title ?? env('APP_NAME', 'Luany')) . ' — Compiler-grade PHP MVC')

@push('head')
    <meta name="description" content="Luany — AST-based MVC framework for PHP 8.1+. No regex template parsing. Deterministic pipeline. Explicit lifecycle.">
    <meta property="og:title" content="Luany Framework">
    <meta property="og:type"  content="website">
@endpush

@style

/* ════════════════════════════════════════════════════════════
   HOME PAGE
   ════════════════════════════════════════════════════════════ */

/* ── Shared grid overlay ─────────────────────────────────── */
.page-grid {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
        linear-gradient(rgba(91,49,113,.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(91,49,113,.035) 1px, transparent 1px);
    background-size: 48px 48px;
}

/* ════════════════════════════════════════════════════════════
   HERO
   ════════════════════════════════════════════════════════════ */
.hero {
    position: relative;
    padding: clamp(5rem, 12vw, 9rem) var(--space-6) clamp(4rem, 8vw, 6rem);
    text-align: center;
    overflow: hidden;
}

.hero-glow-a {
    position: absolute;
    width: 80vw; height: 60vw;
    top: -25vw; left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(91,49,113,.26) 0%, transparent 65%);
    pointer-events: none;
    animation: drift-a 20s ease-in-out infinite alternate;
}
.hero-glow-b {
    position: absolute;
    width: 40vw; height: 40vw;
    bottom: -10vw; right: 5vw;
    background: radial-gradient(ellipse, rgba(230,135,74,.11) 0%, transparent 65%);
    pointer-events: none;
    animation: drift-b 25s ease-in-out infinite alternate;
}

@keyframes drift-a { to { transform: translateX(-50%) scale(1.08) translateY(3vh); } }
@keyframes drift-b { to { transform: scale(1.15) translate(-3vw, -4vh); } }

.hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    animation: fadeInUp .6s var(--ease) both;
}

.hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--luany-purple-glass);
    border: 1px solid var(--luany-purple-border);
    color: var(--luany-orange);
    padding: .35rem 1rem;
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: var(--space-8);
}
.hero-eyebrow-dot {
    width: 6px; height: 6px;
    border-radius: var(--radius-full);
    background: var(--luany-orange);
    animation: pulse-dot 2s ease infinite;
}
@keyframes pulse-dot {
    0%,100% { opacity: 1; transform: scale(1); }
    50%      { opacity: .45; transform: scale(.7); }
}

.hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 7vw, 5rem);
    font-weight: 800;
    line-height: 1.06;
    color: var(--color-text);
    margin-bottom: var(--space-6);
    letter-spacing: -.025em;
}
.hero-title-accent {
    background: var(--luany-gradient);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 5s ease infinite;
}

.hero-subtitle {
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 520px;
    margin: 0 auto var(--space-10);
}

.hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-12);
}

/* Stats bar */
.hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 0;
    background: var(--luany-dark-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    overflow: hidden;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    animation: fadeInUp .6s var(--ease) .2s both;
}
.hero-stat {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: .5rem 1.25rem;
    color: var(--color-text-muted);
}
.hero-stat + .hero-stat {
    border-left: 1px solid var(--color-border);
}
.hero-stat-val {
    color: var(--luany-orange);
    font-weight: 700;
}

/* ════════════════════════════════════════════════════════════
   LTE PLAYGROUND
   ════════════════════════════════════════════════════════════ */
.playground {
    position: relative;
    z-index: 1;
    padding: var(--space-16) var(--space-6);
    border-top: 1px solid var(--color-border);
    background: var(--luany-dark-mid);
}
.playground-inner {
    max-width: 1100px;
    margin: 0 auto;
}
.playground-header {
    text-align: center;
    margin-bottom: var(--space-12);
}
.section-eyebrow {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--luany-orange);
    margin-bottom: var(--space-3);
}
.section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -.015em;
    margin-bottom: var(--space-4);
}
.section-lead {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
}

/* Tabs */
.pg-tabs {
    display: flex;
    gap: 2px;
    background: var(--luany-dark-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    padding: var(--space-1);
    width: fit-content;
    margin-bottom: -1px;
    position: relative;
    z-index: 1;
}
.pg-tab {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: .07em;
    text-transform: uppercase;
    padding: .45rem 1.1rem;
    border-radius: calc(var(--radius-md) - 2px);
    border: none;
    cursor: pointer;
    background: transparent;
    color: var(--color-text-muted);
    transition: all var(--transition);
}
.pg-tab:hover { color: var(--color-text); }
.pg-tab.is-active {
    background: var(--luany-purple-glass);
    border: 1px solid var(--luany-purple-border);
    color: var(--luany-orange);
}

/* Panel grid */
.pg-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: 0 var(--radius-lg) var(--radius-lg) var(--radius-lg);
    overflow: hidden;
    background: var(--luany-dark-card);
}

/* Left — code display */
.pg-code {
    border-right: 1px solid var(--color-border);
    background: var(--luany-dark);
}
.pg-code-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .75rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    background: rgba(0,0,0,.25);
}
.pg-code-label {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
}
.pg-code-lang {
    font-family: var(--font-display);
    font-size: .65rem;
    color: var(--luany-purple-mid);
    letter-spacing: .05em;
}
.pg-code pre {
    margin: 0;
    padding: 1.5rem;
    font-family: var(--font-display);
    font-size: .78rem;
    line-height: 1.9;
    color: rgba(255,255,255,.7);
    overflow-x: auto;
    tab-size: 4;
    white-space: pre;
}

/* Syntax colours */
.tok-directive { color: #C792EA; }
.tok-tag       { color: #89DDFF; }
.tok-attr      { color: #FFCB6B; }
.tok-expr      { color: var(--luany-orange); }
.tok-str       { color: #C3E88D; }
.tok-php       { color: #82AAFF; }
.tok-comment   { color: rgba(255,255,255,.3); font-style: italic; }
.tok-punct     { color: rgba(255,255,255,.4); }

/* Right — output */
.pg-output {
    background: var(--luany-dark-card);
}
.pg-output-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: .75rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    background: rgba(0,0,0,.15);
}
.pg-output-dot {
    width: 7px; height: 7px;
    border-radius: var(--radius-full);
    background: var(--luany-orange);
    animation: pulse-dot 2s ease infinite;
}
.pg-output-label {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
}
.pg-output-badge {
    margin-left: auto;
    font-family: var(--font-display);
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    background: rgba(34,197,94,.12);
    border: 1px solid rgba(34,197,94,.25);
    color: #4ade80;
    padding: .2rem .6rem;
    border-radius: var(--radius-full);
}
.pg-output-body {
    padding: 1.5rem;
}

/* Output: foreach result */
.pg-user-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
}
.pg-user-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: .6rem 1rem;
    background: var(--luany-dark-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--color-text);
    animation: fadeInUp .3s var(--ease) both;
}
.pg-user-item:nth-child(1) { animation-delay: .05s; }
.pg-user-item:nth-child(2) { animation-delay: .1s; }
.pg-user-item:nth-child(3) { animation-delay: .15s; }
.pg-user-item:nth-child(4) { animation-delay: .2s; }
.pg-user-idx {
    font-size: .65rem;
    color: var(--color-text-faint);
    width: 1.2rem;
    text-align: right;
    flex-shrink: 0;
}

/* Output: escaping demo */
.pg-escape-demo {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
}
.pg-escape-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
}
.pg-escape-label {
    font-family: var(--font-display);
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: .2rem .5rem;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    margin-top: .1rem;
}
.pg-escape-safe   { background: rgba(34,197,94,.12); color: #4ade80; border: 1px solid rgba(34,197,94,.25); }
.pg-escape-raw    { background: rgba(230,135,74,.12); color: var(--luany-orange); border: 1px solid rgba(230,135,74,.25); }
.pg-escape-value {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
    word-break: break-all;
}
.pg-escape-value strong { color: var(--color-text); }

/* Panel visibility */
.pg-panel { display: none; }
.pg-panel.is-visible { display: grid; grid-template-columns: 1fr 1fr; }

@media (max-width: 768px) {
    .pg-panels, .pg-panel.is-visible { grid-template-columns: 1fr; }
    .pg-code { border-right: none; border-bottom: 1px solid var(--color-border); }
}

/* ════════════════════════════════════════════════════════════
   PIPELINE
   ════════════════════════════════════════════════════════════ */
.pipeline {
    position: relative;
    z-index: 1;
    padding: var(--space-16) var(--space-6);
    border-top: 1px solid var(--color-border);
}
.pipeline-inner {
    max-width: 900px;
    margin: 0 auto;
}
.pipeline-header {
    text-align: center;
    margin-bottom: var(--space-12);
}
.pipeline-flow {
    display: flex;
    flex-direction: column;
    gap: 0;
}
.pipe-step {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--space-4);
    align-items: flex-start;
}
.pipe-step + .pipe-step .pipe-icon-col::before {
    content: '';
    display: block;
    width: 1px;
    height: var(--space-6);
    background: linear-gradient(to bottom, var(--luany-purple-border), transparent);
    margin: 0 auto var(--space-2);
}
.pipe-icon-col {
    display: flex;
    flex-direction: column;
    align-items: center;
}
.pipe-icon {
    width: 48px; height: 48px;
    border-radius: var(--radius-md);
    background: var(--luany-purple-glass);
    border: 1px solid var(--luany-purple-border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--luany-orange);
}
.pipe-body {
    padding-top: .75rem;
    padding-bottom: var(--space-8);
}
.pipe-name {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-1);
    letter-spacing: .02em;
}
.pipe-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
}
.pipe-code {
    margin-top: var(--space-2);
    display: inline-block;
    font-family: var(--font-display);
    font-size: .72rem;
    color: var(--luany-purple-mid);
    background: var(--luany-purple-glass);
    border: 1px solid var(--luany-purple-border);
    padding: .2rem .6rem;
    border-radius: var(--radius-sm);
}

/* ════════════════════════════════════════════════════════════
   FEATURES
   ════════════════════════════════════════════════════════════ */
.features {
    position: relative;
    z-index: 1;
    padding: var(--space-16) var(--space-6);
    background: var(--luany-dark-mid);
    border-top: 1px solid var(--color-border);
}
.features-inner  { max-width: 1100px; margin: 0 auto; }
.features-header { text-align: center; margin-bottom: var(--space-12); }

.features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
}
.feature-card {
    background: var(--luany-dark-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8) var(--space-6);
    position: relative;
    overflow: hidden;
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
}
.feature-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 80% at 10% 10%, rgba(91,49,113,.12) 0%, transparent 60%);
    opacity: 0;
    transition: opacity var(--transition-slow);
}
.feature-card:hover {
    border-color: var(--luany-purple-border);
    transform: translateY(-4px);
    box-shadow: var(--shadow-glow-purple);
}
.feature-card:hover::before { opacity: 1; }

.feature-icon {
    width: 44px; height: 44px;
    border-radius: var(--radius-md);
    background: var(--luany-purple-glass);
    border: 1px solid var(--luany-purple-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-4);
    color: var(--luany-orange);
    position: relative;
    z-index: 1;
}
.feature-name {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-2);
    position: relative; z-index: 1;
}
.feature-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    position: relative; z-index: 1;
}

/* ════════════════════════════════════════════════════════════
   CTA
   ════════════════════════════════════════════════════════════ */
.cta {
    position: relative;
    z-index: 1;
    padding: var(--space-16) var(--space-6);
    border-top: 1px solid var(--color-border);
    text-align: center;
    overflow: hidden;
}
.cta-glow {
    position: absolute;
    width: 60vw; height: 40vw;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse, rgba(91,49,113,.2) 0%, transparent 65%);
    pointer-events: none;
}
.cta-inner {
    position: relative;
    z-index: 1;
    max-width: 560px;
    margin: 0 auto;
}
.cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -.02em;
    margin-bottom: var(--space-4);
    line-height: 1.1;
}
.cta-title span {
    background: var(--luany-gradient);
    background-size: 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 4s ease infinite;
}
.cta-sub {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    line-height: 1.7;
}
.cta-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
}
.cta-version {
    margin-top: var(--space-6);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    letter-spacing: .05em;
}

@endstyle

