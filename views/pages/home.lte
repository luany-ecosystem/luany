@script(defer)
(function () {
    'use strict';

    // ── Playground tabs ───────────────────────────────────────
    var tabs   = document.querySelectorAll('.pg-tab');
    var panels = document.querySelectorAll('.pg-panel');

    tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
            var target = tab.dataset.tab;

            tabs.forEach(function (t) {
                t.classList.remove('is-active');
                t.setAttribute('aria-selected', 'false');
            });
            panels.forEach(function (p) {
                p.classList.remove('is-visible');
            });

            tab.classList.add('is-active');
            tab.setAttribute('aria-selected', 'true');

            var panel = document.getElementById('pg-' + target);
            if (panel) panel.classList.add('is-visible');
        });
    });

    // ── Feature cards — scroll-triggered entrance ─────────────
    var cards = document.querySelectorAll('.feature-card');
    if (!cards.length || !('IntersectionObserver' in window)) return;

    var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry, i) {
            if (entry.isIntersecting) {
                entry.target.style.animationDelay = (i * 0.08) + 's';
                entry.target.style.animation = 'fadeInUp .45s var(--ease) both';
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.12 });

    cards.forEach(function (c) { observer.observe(c); });

}());
@endscript
