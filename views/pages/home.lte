{{-- ════════════════ PIPELINE ════════════════ --}}
<section class="pipeline">
    <div class="pipeline-inner">

        <div class="pipeline-header">
            <p class="section-eyebrow">Request Lifecycle</p>
            <h2 class="section-title">Explicit by design</h2>
        </div>

        <div class="pipeline-flow" role="list">

            <div class="pipe-step" role="listitem">
                <div class="pipe-icon-col">
                    <div class="pipe-icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
