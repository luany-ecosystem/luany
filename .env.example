# ============================================================
# Luany — Environment Configuration
# ============================================================
# Copy this file to .env and edit the values.
# NEVER commit .env with real credentials.

APP_NAME="Luany"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=
APP_TIMEZONE=UTC

# ── Database ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=luany
DB_USER=root
DB_PASS=

# ── Mail (optional) ──────────────────────────────────────────
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME="${APP_NAME}"
