{
    "name": "luany/luany",
    "description": "Official application skeleton for the Luany Framework — AST-compiled PHP MVC with an explicit request lifecycle and zero-regex template engine.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "António Ambrósio Ngola",
            "email": "antoniongola.dev@gmail.com",
            "homepage": "https://github.com/luany-ecosystem",
            "role": "Lead Engineer"
        }
    ],
    "keywords": [
        "php",
        "framework",
        "mvc",
        "ast",
        "lte",
        "luany",
        "skeleton"
    ],
    "homepage": "https://github.com/luany-ecosystem/luany",
    "require": {
        "php": ">=8.1",
        "luany/framework": "^0.4",
        "luany/database": "^0.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php bin/post-install.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
